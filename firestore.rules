rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {uid}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - departmentId: string (required, enum: estoque, recebimento, romaneio_tarde, romaneio_noturno, veiculos, exp_loja, admin)
    //   - displayName: string (optional)
    //
    // Collection: logs
    // Document ID: {logId}
    // Fields:
    //   - date: string (required, YYYY-MM-DD)
    //   - departmentId: string (required)
    //   - staffPresent: number (required)
    //   - occurrences: list (optional)
    //   - data: map (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidLog(data) {
      return data.keys().hasAll(['date', 'departmentId', 'staffPresent']) &&
             data.date is string &&
             data.departmentId is string &&
             data.staffPresent is number &&
             data.staffPresent >= 0;
    }

    match /users/{userId} {
      allow read, write: if isSignedIn();
    }

    match /logs/{logId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isValidLog(request.resource.data);
      allow delete: if isSignedIn();
    }

    match /settings/{settingId} {
      allow read, write: if isSignedIn();
    }

    function isValidAppointment(data) {
      return data.date is string &&
             data.creationDate is string &&
             data.staff is string &&
             data.requester is string &&
             data.orderNumber is string &&
             data.supplier is string &&
             data.vehicle is string &&
             data.scheduledTime is string &&
             data.observation is string &&
             data.collaborator is string &&
             data.pallets is number &&
             data.totalValue is number &&
             (data.status == 'Agendado' || data.status == 'Aguardando' || data.status == 'Descarregando' || data.status == 'Recebido' || data.status == 'Cancelado');
    }

    match /appointments/{appointmentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && 
                    isValidAppointment(request.resource.data) &&
                    request.resource.data.createdAt == request.time;
      allow update: if isSignedIn() && 
                    (isValidAppointment(request.resource.data) || 
                     (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) || 
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['deleted'])));
      allow delete: if isSignedIn();
    }

    match /presence/{uid} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
