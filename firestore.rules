rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {uid}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - departmentId: string (required, enum: estoque, recebimento, romaneio_tarde, romaneio_noturno, veiculos, exp_loja, admin)
    //   - displayName: string (optional)
    //
    // Collection: logs
    // Document ID: {logId}
    // Fields:
    //   - date: string (required, YYYY-MM-DD)
    //   - departmentId: string (required)
    //   - staffPresent: number (required)
    //   - occurrences: list (optional)
    //   - data: map (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isValidLog(data) {
      return data.keys().hasAll(['date', 'departmentId', 'staffPresent']) &&
             data.date is string &&
             data.departmentId is string &&
             data.staffPresent is number &&
             data.staffPresent >= 0;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read, write: if isAuthenticated();
    }

    match /logs/{logId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isValidLog(request.resource.data);
      allow delete: if isAuthenticated();
    }

    match /settings/{settingId} {
      allow read, write: if isAuthenticated();
    }

    match /appointments/{appointmentId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }
  }
}
